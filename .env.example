# Database
DB_ROOT_PASSWORD=your_secure_root_password
DB_USER=invitapp_user
DB_PASSWORD=your_secure_password
DB_NAME=invitaciones_saas

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET=change_me_to_a_secure_random_string_access
JWT_REFRESH_SECRET=change_me_to_a_secure_random_string_refresh

# SSL Certificate Email
ACME_EMAIL=your-email@example.com

# Seed database on first boot (set to false after first deployment)
SEED_ON_BOOT=true

# Migration mode: normal or fresh
# WARNING: fresh will DROP ALL DATA and recreate the database
# Use 'fresh' only for initial deployment or when you want to reset everything
# Use 'normal' for regular deployments (default)
MIGRATION_MODE=normal
