# ─── Database ─────────────────────────────────────────────────
DB_ROOT_PASSWORD=your_secure_root_password
DB_USER=invitapp_user
DB_PASSWORD=your_secure_password
DB_NAME=invitaciones_saas

# ─── JWT Secrets ──────────────────────────────────────────────
# CHANGE THESE in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_secure_random_string_access
JWT_REFRESH_SECRET=change_me_to_a_secure_random_string_refresh

# ─── SSL Certificate ──────────────────────────────────────────
ACME_EMAIL=your-email@example.com

# ─── Migration / Seed Behavior ────────────────────────────────
# Migration mode: normal | fresh
#   normal → idempotent CREATE/ALTER (safe)
#   fresh  → DROPS ALL TABLES (only for first deploy or full reset)
# In production, MIGRATION_MODE=fresh is REJECTED unless
# ALLOW_FRESH_IN_PRODUCTION=true is also set.
MIGRATION_MODE=normal

# Seed (initial roles, plans, permissions, optional SuperAdmin / demo).
# Set to false after the first successful deploy.
# In production, SEED_ON_BOOT=true is REJECTED unless
# ALLOW_SEED_IN_PRODUCTION=true is also set.
SEED_ON_BOOT=false

# ─── Optional Seed Identities (only used when SEED_ON_BOOT=true) ──
# If SEED_SUPERADMIN_EMAIL is unset, no SuperAdmin is created.
# If SEED_SUPERADMIN_PASSWORD is unset, a temporary one is generated
# and printed once. The created user has must_change_password=1.
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_PASSWORD=

# Demo tenant — only created when SEED_DEMO_TENANT=true.
# Use only in dev/staging.
SEED_DEMO_TENANT=false
SEED_DEMO_OWNER_EMAIL=
SEED_DEMO_OWNER_NAME=Demo Owner
SEED_DEMO_OWNER_PASSWORD=
SEED_DEMO_COMPANY_NAME=Demo Company
