# Server
NODE_ENV=development
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=invitaciones_saas

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
# Window in milliseconds (60000 = 1 minute, 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window (500 recommended for normal use, 100 was too restrictive)
RATE_LIMIT_MAX=500
# Max login attempts per 15 minutes
LOGIN_RATE_LIMIT_MAX=10

# App
APP_DOMAIN=localhost
APP_PROTOCOL=http
FRONTEND_URL=http://localhost:3000
