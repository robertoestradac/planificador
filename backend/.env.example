# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=invitaciones_saas

# ─── JWT ──────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── CORS ─────────────────────────────────────────────────────
# In production, only origins listed here (comma-separated) are allowed.
# In development, localhost / 127.0.0.1 are also allowed automatically.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=10

# ─── App ──────────────────────────────────────────────────────
APP_DOMAIN=localhost
APP_PROTOCOL=http
FRONTEND_URL=http://localhost:3000

# ─── Seed Identities (used by `npm run seed`) ─────────────────
# Leave SEED_SUPERADMIN_EMAIL empty to skip creating a SuperAdmin.
# If SEED_SUPERADMIN_PASSWORD is empty, a random one is generated
# and printed once. The user is created with must_change_password=1
# and must rotate the password on first login.
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_PASSWORD=

# Demo tenant — only created when SEED_DEMO_TENANT=true.
# Use only in dev/staging, never in production.
SEED_DEMO_TENANT=false
SEED_DEMO_OWNER_EMAIL=
SEED_DEMO_OWNER_NAME=Demo Owner
SEED_DEMO_OWNER_PASSWORD=
SEED_DEMO_COMPANY_NAME=Demo Company
